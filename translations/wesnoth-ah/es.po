#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:10
msgid "Explore and identify where the temple is located"
msgstr "Explora e identifica dónde se encuentra el templo"

#. [objective], condition=win
#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:14
msgid "Objective II:"
msgstr "Objetivo II:"

#. [objective], condition=win
#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:15
msgid "Enter the temple with Herkarth"
msgstr "Entra al templo con Herkarth"

#. [objective], condition=win
#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:19
msgid "Objective III:"
msgstr "Objetivo III:"

#. [objective], condition=win
#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:20
msgid "Defeat the dwarven commanders"
msgstr "Derrota a los comandantes enanos"

#. [objective], condition=win
#: ./Ashen_Hearts/scenarios/scenario-utils/05_Runic_Gate-utils.cfg:28
msgid "Optional Objective:"
msgstr "Objetivo opcional:"

