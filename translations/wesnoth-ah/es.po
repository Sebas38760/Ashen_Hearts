#: ./Ashen_Hearts/macros/schedule-macro.cfg:19
msgid "Presence of the Dragonheart"
msgstr "Presencia del Corazón de Dragón"

#. [time], id=temple_of_the_drakes
#: ./Ashen_Hearts/macros/schedule-macro.cfg:31
msgid "Temple of the Drakes"
msgstr "Templo de los Dracos"

